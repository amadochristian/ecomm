# ============================================================
# ⚙️ VARIÁVEIS DE AMBIENTE — .env.example
# ============================================================
# Copie este arquivo para .env.local para desenvolvimento local
# Configure todas essas variáveis no painel da Vercel em produção
# ⚠️ NUNCA commite o arquivo .env com valores reais no Git

# ——— SUPABASE ———
# Encontre no painel: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx  # Chave de serviço (só no backend!)

# ——— MERCADO PAGO ———
# Encontre em: https://www.mercadopago.com.br/developers → Credenciais
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx   # Token de produção ou TEST-xxxx para sandbox
MP_PUBLIC_KEY=APP_USR-xxxx                     # Chave pública (pode estar no frontend)

# ——— MELHOR ENVIO ———
# Encontre em: https://melhorenvio.com.br → Minha Conta → Tokens
MELHOR_ENVIO_TOKEN=eyJhbGciOiJSUzI1NiJ9.xxxx
MELHOR_ENVIO_SANDBOX=false   # true para testes

# ——— RESEND ———
# Encontre em: https://resend.com → API Keys
RESEND_API_KEY=re_xxxx

# ——— CONFIGURAÇÕES GERAIS ———
BASE_URL=https://bragshirt.com.br              # URL do site em produção
CEP_ORIGEM=12900000                            # CEP de origem para cálculo de frete
NODE_ENV=production
